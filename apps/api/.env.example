DATABASE_URL="postgresql://user:password@host:5432/courier_saas"
JWT_SECRET="change-this-to-a-random-string-min-32-chars"
JWT_REFRESH_SECRET="change-this-refresh-secret-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"
EMAIL_FROM="noreply@yourdomain.com"
SMTP_HOST="smtp.gmail.com"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
DISABLE_RATE_LIMIT=false

# Redis / performance
REDIS_ENABLED=true
# For Upstash use: rediss://default:<token>@<host>:6379
REDIS_URL=""
# Used when REDIS_URL is empty (local Redis fallback)
REDIS_HOST="127.0.0.1"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# Caching
CACHE_ENABLED=true
CACHE_TTL_SECONDS=45
CACHE_ANALYTICS_TTL_SECONDS=60
CACHE_TRACKING_TTL_SECONDS=30
CACHE_SHIPMENTS_TTL_SECONDS=20
CACHE_WORKITEMS_TTL_SECONDS=15
CACHE_AVAILABLE_AGENTS_TTL_SECONDS=30

# Background jobs (BullMQ)
QUEUES_ENABLED=true
EMAIL_QUEUE_CONCURRENCY=4
